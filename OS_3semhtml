<style>
:root {
  --bg: #070a0f;
  --surface: #0d1018;
  --card: #101420;
  --border: #1a2030;
  --border-b: #252e42;
  --gold: #f0c060;
  --gold-dim: #8a6820;
  --gold-glow: rgba(240,192,96,0.1);
  --teal: #3dd6b5;
  --rose: #ff7b7b;
  --blue: #6ab4ff;
  --purple: #c4a0ff;
  --green: #7dd5a0;
  --text: #dce6f5;
  --soft: #b0bccf;
  --muted: #5a6880;
  --white: #f4f8ff;
  --u1: #3dd6b5; --u2: #6ab4ff; --u3: #ff7b7b;
  --u4: #c4a0ff; --u5: #f0c060; --u6: #7dd5a0;
