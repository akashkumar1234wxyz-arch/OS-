        <h4>Semaphore Solution — First Readers Priority</h4>
        <pre><span class="cm">/* Reader Process */</span>
<span class="fn">wait</span>(mutex);            <span class="cm">// Lock to safely update read_count</span>
read_count++;
<span class="kw">if</span> (read_count == <span class="num">1</span>)    <span class="cm">// First reader locks out writers</span>
    <span class="fn">wait</span>(rw_mutex);
<span class="fn">signal</span>(mutex);
<span class="cm">/* ════ READ THE DATA ════ */</span>
<span class="fn">wait</span>(mutex);
read_count--;
<span class="kw">if</span> (read_count == <span class="num">0</span>)    <span class="cm">// Last reader releases write lock</span>
    <span class="fn">signal</span>(rw_mutex);
<span class="fn">signal</span>(mutex);

<span class="cm">/* Writer Process */</span>
<span class="fn">wait</span>(rw_mutex);         <span class="cm">// Gain exclusive access</span>
<span class="cm">/* ════ WRITE THE DATA ════ */</span>
<span class="fn">signal</span>(rw_mutex);</pre>
