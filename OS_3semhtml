.def{background:rgba(61,214,181,0.045);border-left:3px solid var(--teal);border-radius:0 9px 9px 0;padding:14px 18px;margin:16px 0;font-size:14px;line-height:1.72;}
.def strong{color:var(--teal);font-weight:600;}
.note{background:rgba(106,180,255,0.045);border-left:3px solid var(--blue);border-radius:0 9px 9px 0;padding:13px 18px;margin:14px 0;font-size:13.5px;line-height:1.7;color:var(--soft);}

/* ── TABLE ── */
.tbl{width:100%;border-collapse:collapse;margin:16px 0;font-size:13.5px;border-radius:10px;overflow:hidden;border:1px solid var(--border);}
.tbl th{background:rgba(255,255,255,0.035);color:var(--gold);font-family:'Fira Code',monospace;font-size:10.5px;letter-spacing:0.9px;text-transform:uppercase;padding:11px 16px;text-align:left;border-bottom:1px solid var(--border-b);font-weight:500;}
.tbl td{padding:10px 16px;border-bottom:1px solid rgba(26,32,48,0.8);vertical-align:top;line-height:1.65;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:nth-child(even) td{background:rgba(255,255,255,0.016);}
.tbl td strong{color:var(--blue);font-weight:600;}
.tbl .hi{color:var(--green);font-weight:700;}
.tbl .lo{color:var(--rose);}

/* ── CODE ── */
pre{background:#05070d;border:1px solid var(--border);border-radius:11px;padding:18px 20px;margin:16px 0;overflow-x:auto;font-family:'Fira Code',monospace;font-size:13px;line-height:1.72;color:#9fb4d0;position:relative;}
pre::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--teal),transparent 60%);opacity:0.35;}
pre .kw{color:#6ab4ff;font-weight:500;}
pre .cm{color:#2e3a50;font-style:italic;}
pre .str{color:#7dd5a0;}
pre .fn{color:#f0c060;font-weight:500;}
pre .num{color:#c4a0ff;}
code{font-family:'Fira Code',monospace;font-size:13px;background:rgba(255,255,255,0.055);padding:1px 6px;border-radius:4px;color:var(--teal);}

/* ── DIAGRAM WRAP ── */
.dw{background:#06080e;border:1px solid var(--border);border-radius:13px;padding:22px;margin:18px 0;display:flex;flex-direction:column;align-items:center;position:relative;overflow:hidden;}
