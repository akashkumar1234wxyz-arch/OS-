.dw svg{max-width:100%;height:auto;}
.dlbl{font-family:'Fira Code',monospace;font-size:10px;color:var(--muted);letter-spacing:1.8px;text-transform:uppercase;margin-top:14px;}

/* ── MCQ ── */
.mcq{background:rgba(240,192,96,0.03);border:1px solid rgba(240,192,96,0.1);border-radius:10px;padding:16px 20px;margin-bottom:10px;transition:border-color 0.2s;}
.mcq:hover{border-color:rgba(240,192,96,0.22);}
.mcq-q{color:var(--text);margin-bottom:8px;font-weight:600;line-height:1.55;}
.mcq-a{color:var(--green);font-family:'Fira Code',monospace;font-size:12.5px;font-weight:500;}
.mcq-r{color:var(--muted);font-size:13px;margin-top:5px;line-height:1.55;}

/* ── GANTT ── */
.gantt-wrap{overflow-x:auto;margin:16px 0;}
.gantt{display:flex;align-items:stretch;min-width:560px;height:52px;border-radius:6px;overflow:hidden;font-family:'Fira Code',monospace;}
.gc{display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:11.5px;letter-spacing:0.4px;border-right:1px solid rgba(0,0,0,0.3);flex-shrink:0;}
.gt{display:flex;min-width:560px;font-family:'Fira Code',monospace;font-size:10px;color:var(--muted);margin-top:5px;}

/* ── SCROLL UP BTN ── */
#scroll-up{position:fixed;bottom:28px;right:28px;z-index:9000;width:46px;height:46px;background:rgba(240,192,96,0.12);border:1px solid var(--gold-dim);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transform:translateY(16px);transition:all 0.35s ease;font-size:18px;color:var(--gold);}
#scroll-up.show{opacity:1;transform:translateY(0);}
#scroll-up:hover{background:rgba(240,192,96,0.22);box-shadow:0 0 24px rgba(240,192,96,0.2);}

/* ── PROGRESS BAR ── */
#progress{position:fixed;top:0;left:0;z-index:9999;height:2px;background:linear-gradient(90deg,var(--teal),var(--gold),var(--blue));width:0%;transition:width 0.1s linear;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border-b);border-radius:3px;}
::-webkit-scrollbar-thumb:hover{background:var(--muted);}

@media(max-width:640px){
  .hero{padding:56px 20px 48px;}
  .hero-ghost{display:none;}
  .nav{padding:10px 16px;}
  .main{padding:32px 12px 68px;}
  .unit-hdr{padding:20px 20px;}
  .unit-num{font-size:42px;}
}
</style>
