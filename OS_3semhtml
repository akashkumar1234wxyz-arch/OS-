*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.75;-webkit-font-smoothing:antialiased;overflow-x:hidden;}

/* ── PARTICLE CANVAS ── */
#bg-canvas{position:fixed;inset:0;pointer-events:none;z-index:0;opacity:0.45;}

/* ── PRELOADER ── */
#preloader{
  position:fixed;inset:0;z-index:9999;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity 0.9s ease, visibility 0.9s ease;
}
#preloader.hide{opacity:0;visibility:hidden;pointer-events:none;}
.pl-icon{font-size:52px;animation:plPulse 1.4s ease infinite;filter:drop-shadow(0 0 24px rgba(240,192,96,0.5));}
@keyframes plPulse{0%,100%{transform:scale(1);}50%{transform:scale(1.18);}}
.pl-text{margin-top:24px;font-family:'Fira Code',monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);opacity:0;animation:fadeUp 0.7s 0.4s ease forwards;}
.pl-bar{margin-top:28px;width:220px;height:2px;background:rgba(240,192,96,0.12);border-radius:99px;overflow:hidden;}
.pl-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--gold),var(--blue));border-radius:99px;animation:fillBar 2.2s cubic-bezier(0.4,0,0.2,1) forwards;}
@keyframes fillBar{from{width:0;}to{width:100%;}}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(36px);transition:opacity 0.75s cubic-bezier(0.22,1,0.36,1),transform 0.75s cubic-bezier(0.22,1,0.36,1);}
.reveal.vis{opacity:1;transform:translateY(0);}
.reveal-l{opacity:0;transform:translateX(-30px);transition:opacity 0.7s ease,transform 0.7s ease;}
.reveal-l.vis{opacity:1;transform:translateX(0);}

/* ── HERO ── */
.hero{
  position:relative;z-index:1;
  padding:88px 40px 72px;text-align:center;
  border-bottom:1px solid var(--border);
  overflow:hidden;
}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% -5%,rgba(240,192,96,0.09) 0%,transparent 65%),radial-gradient(ellipse 40% 30% at 15% 90%,rgba(61,214,181,0.045) 0%,transparent 60%),radial-gradient(ellipse 40% 30% at 85% 90%,rgba(106,180,255,0.045) 0%,transparent 60%);pointer-events:none;}
.hero-ghost{position:absolute;right:-10px;top:-30px;font-family:'DM Serif Display',serif;font-size:300px;color:rgba(240,192,96,0.018);line-height:1;pointer-events:none;user-select:none;font-style:italic;}
.hero-badge{display:inline-block;font-family:'Fira Code',monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);border:1px solid var(--gold-dim);padding:6px 18px;border-radius:2px;margin-bottom:28px;background:rgba(240,192,96,0.04);opacity:0;animation:fadeUp 0.8s 2.5s ease forwards;}
.hero h1{font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,6.5vw,4.6rem);font-weight:400;color:var(--white);letter-spacing:-0.5px;line-height:1.04;margin-bottom:18px;opacity:0;animation:fadeUp 0.9s 2.8s ease forwards;}
.hero h1 em{color:var(--gold);font-style:italic;}
.hero-sub{font-size:14.5px;color:var(--muted);opacity:0;animation:fadeUp 0.8s 3.1s ease forwards;}
.hero-meta{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:30px;opacity:0;animation:fadeUp 0.8s 3.4s ease forwards;}
.hero-meta span{font-family:'Fira Code',monospace;font-size:11px;color:var(--muted);border:1px solid var(--border-b);padding:5px 14px;border-radius:20px;background:rgba(255,255,255,0.018);letter-spacing:0.5px;}

/* ── NAV ── */
.nav{position:sticky;top:0;z-index:100;background:rgba(7,10,15,0.96);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);padding:11px 40px;display:flex;gap:6px;flex-wrap:wrap;justify-content:center;}
.nav a{font-family:'Fira Code',monospace;font-size:10.5px;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);text-decoration:none;padding:5px 14px;border-radius:4px;border:1px solid transparent;transition:all 0.25s ease;}
.nav a:hover,.nav a.active{color:var(--gold);border-color:var(--gold-dim);background:var(--gold-glow);}

/* ── MAIN ── */
.main{max-width:990px;margin:0 auto;padding:52px 24px 100px;position:relative;z-index:1;}

/* ── UNIT ── */
.unit{margin-bottom:68px;border-radius:16px;overflow:hidden;border:1px solid var(--border);box-shadow:0 6px 40px rgba(0,0,0,0.35);}
.unit-hdr{padding:28px 32px;display:flex;align-items:center;gap:20px;cursor:pointer;user-select:none;transition:background 0.25s;position:relative;}
.unit-hdr:hover{background:rgba(255,255,255,0.012);}
.unit-num{font-family:'DM Serif Display',serif;font-size:58px;font-weight:400;opacity:0.075;line-height:1;flex-shrink:0;font-style:italic;}
.unit-info{flex:1;}
.unit-info h2{font-family:'DM Serif Display',serif;font-size:1.5rem;font-weight:400;color:var(--white);line-height:1.2;letter-spacing:-0.3px;}
.unit-info p{font-size:11.5px;color:var(--muted);margin-top:6px;font-family:'Fira Code',monospace;letter-spacing:0.2px;}
.unit-arrow{color:var(--muted);font-size:16px;transition:transform 0.35s ease;}
.unit.open .unit-arrow{transform:rotate(180deg);}
.unit-body{display:none;padding:0 22px 22px;}
.unit.open .unit-body{display:block;}

.u1 .unit-hdr{background:linear-gradient(100deg,rgba(61,214,181,0.055) 0%,transparent 50%);border-left:3px solid var(--u1);}
.u2 .unit-hdr{background:linear-gradient(100deg,rgba(106,180,255,0.055) 0%,transparent 50%);border-left:3px solid var(--u2);}
.u3 .unit-hdr{background:linear-gradient(100deg,rgba(255,123,123,0.055) 0%,transparent 50%);border-left:3px solid var(--u3);}
.u4 .unit-hdr{background:linear-gradient(100deg,rgba(196,160,255,0.055) 0%,transparent 50%);border-left:3px solid var(--u4);}
.u5 .unit-hdr{background:linear-gradient(100deg,rgba(240,192,96,0.055) 0%,transparent 50%);border-left:3px solid var(--u5);}
.u6 .unit-hdr{background:linear-gradient(100deg,rgba(125,213,160,0.055) 0%,transparent 50%);border-left:3px solid var(--u6);}

/* ── QCARD ── */
.qcard{background:var(--card);border:1px solid var(--border);border-radius:12px;margin-bottom:14px;overflow:hidden;transition:border-color 0.3s,box-shadow 0.3s,transform 0.2s;}
.qcard:hover{border-color:var(--border-b);box-shadow:0 4px 28px rgba(0,0,0,0.25);transform:translateY(-1px);}
.qcard-hdr{padding:18px 22px;display:flex;align-items:flex-start;gap:14px;cursor:pointer;}
.qbadge{font-family:'Fira Code',monospace;font-size:10px;font-weight:600;letter-spacing:0.8px;padding:3px 9px;border-radius:5px;white-space:nowrap;flex-shrink:0;margin-top:3px;}
.m7{background:rgba(196,160,255,0.1);color:var(--purple);border:1px solid rgba(196,160,255,0.25);}
.m4{background:rgba(106,180,255,0.1);color:var(--blue);border:1px solid rgba(106,180,255,0.25);}
.m3{background:rgba(61,214,181,0.1);color:var(--teal);border:1px solid rgba(61,214,181,0.25);}
.m2{background:rgba(240,192,96,0.1);color:var(--gold);border:1px solid rgba(240,192,96,0.25);}
.mbq{background:rgba(240,192,96,0.07);color:var(--gold);border:1px solid rgba(240,192,96,0.18);font-family:'Fira Code',monospace;font-size:10px;padding:3px 9px;border-radius:5px;}
.qcard-hdr h3{font-size:14.5px;font-weight:600;color:var(--white);line-height:1.5;flex:1;}
.ytag{font-family:'Fira Code',monospace;font-size:10px;color:var(--gold);background:rgba(240,192,96,0.08);padding:2px 7px;border-radius:3px;margin-left:6px;font-weight:400;}
